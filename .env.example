APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8080

DATABASE_URL=jdbc:postgresql://postgres:5432/saas_tracker
# Use strong, unique credentials in production (never use defaults)
DATABASE_USER=change-me-db-user
DATABASE_PASSWORD=change-me-db-password
DATABASE_MAX_POOL_SIZE=12

REDIS_URL=redis://redis:6379
REDIS_CACHE_TTL_SECONDS=900

JWT_ISSUER=saas-subscription-tracker
JWT_AUDIENCE=saas-subscription-tracker-users
# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=change-me-super-long-jwt-secret-at-least-32-bytes
JWT_ACCESS_TTL_MINUTES=60

# ── Email Provider ────────────────────────────────────────────
# Options: smtp (default, local dev) | resend (recommended for production)
EMAIL_PROVIDER=smtp

# ── SMTP (Stalwart — local development only) ──────────────────
SMTP_HOST=stalwart
SMTP_PORT=587
SMTP_USERNAME=admin
# Use the generated Stalwart admin password from `docker compose logs stalwart`.
SMTP_PASSWORD=change-me-stalwart-password
SMTP_FROM_EMAIL=no-reply@localhost
SMTP_FROM_NAME=SaaS Subscription Tracker
SMTP_AUTH=true
SMTP_STARTTLS=true
# WARNING: set to false in production — true only for local dev with self-signed certs
SMTP_TLS_TRUST_ALL=false
SMTP_TIMEOUT_MS=10000

# ── Resend (recommended for production) ───────────────────────
# Uncomment and fill in for production. See README → Email Setup → Production.
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_BASE_URL=https://api.resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_BASE_URL=https://api.resend.com

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost/dashboard?upgraded=true
STRIPE_CANCEL_URL=http://localhost/billing/upgrade

RENEWAL_CRON=0 0 9 * * ?
RATE_LIMIT_RPM=120
AUTH_RATE_LIMIT_RPM=10
EXPORT_RATE_LIMIT_RPM=5
# Production: use HTTPS origins only, e.g. https://app.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost
FRONTEND_BASE_URL=http://localhost

POSTGRES_DB=saas_tracker
# Must match DATABASE_USER / DATABASE_PASSWORD above
POSTGRES_USER=change-me-db-user
POSTGRES_PASSWORD=change-me-db-password

STALWART_HTTP_PORT=8081
STALWART_SUBMISSION_PORT=2525
